        if (epoch + 1) % 10 == 0:
            print("Epoch " + str(epoch + 1) + "/" + str(epochs) + " - Train Loss: " + str(round(train_loss, 4)) + " - Val Loss: " + str(round(val_loss, 4)))
            
        if patience_counter >= early_stop_patience:
            print("Early stopping triggered at epoch " + str(epoch + 1))
            break
            
